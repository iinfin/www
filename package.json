{
	"name": "u29dc.com",
	"version": "1.1.3",
	"private": true,
	"repository": "https://github.com/iinfin/www.git",
	"scripts": {
		"setup------------------------------": "",
		"dev": "cross-env NODE_OPTIONS='--inspect' next dev --turbo",
		"build": "next build",
		"build:cloudflare": "npx @cloudflare/next-on-pages --experimental-minify",
		"build:stats": "cross-env ANALYZE=true npm run build",
		"build:prod": "npm run util:clean && npm run build",
		"start": "next start",
		"prepare": "husky install",
		"utils------------------------------": "",
		"util:clean": "rimraf .next out dist build",
		"util:lint": "next lint",
		"util:lint:fix": "next lint --fix",
		"util:lint:staged": "lint-staged --concurrent false",
		"util:prettier": "npx prettier --write ./src --ignore-path .gitignore",
		"util:types": "tsc --noEmit --pretty",
		"tests------------------------------": "",
		"test:all": "echo \"No tests yet\""
	},
	"dependencies": {
		"@next/bundle-analyzer": "^13.3.2",
		"autoprefixer": "^10.4.14",
		"cssnano": "^6.0.1",
		"framer-motion": "^10.12.4",
		"next": "^13.3.2",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"tailwindcss": "^3.3.2"
	},
	"devDependencies": {
		"@commitlint/cli": "^17.6.1",
		"@commitlint/config-conventional": "^17.6.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^9.0.2",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^8.0.7",
		"@semantic-release/npm": "^10.0.3",
		"@semantic-release/release-notes-generator": "^11.0.1",
		"@types/node": "18.16.3",
		"@types/react": "18.2.0",
		"@types/react-dom": "18.2.1",
		"@typescript-eslint/eslint-plugin": "^5.59.1",
		"@typescript-eslint/parser": "^5.59.1",
		"browserslist": "^4.21.5",
		"commitlint": "^17.6.1",
		"cross-env": "^7.0.3",
		"eslint": "^8.39.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-airbnb-typescript": "^17.0.0",
		"eslint-config-next": "^13.3.2",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-jsx-a11y": "^6.7.1",
		"eslint-plugin-prettier": "^4.2.1",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-simple-import-sort": "^10.0.0",
		"eslint-plugin-tailwindcss": "^3.11.0",
		"eslint-plugin-unused-imports": "^2.0.0",
		"husky": "^8.0.3",
		"lint-staged": "^13.2.2",
		"postcss": "^8.4.23",
		"prettier": "^2.8.8",
		"prettier-plugin-css-order": "^1.3.0",
		"prettier-plugin-tailwindcss": "^0.2.8",
		"rimraf": "^5.0.0",
		"sass": "^1.62.1",
		"semantic-release": "^21.0.2",
		"stylelint": "^15.6.0",
		"stylelint-config-recommended": "^12.0.0",
		"stylelint-config-tailwindcss": "^0.0.7",
		"typescript": "5.0.4"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			[
				"@semantic-release/npm",
				{
					"npmPublish": false
				}
			],
			[
				"@semantic-release/github",
				{
					"assets": [
						"CHANGELOG.md"
					]
				}
			],
			[
				"@semantic-release/git",
				{
					"assets": [
						"CHANGELOG.md",
						"package.json"
					],
					"message": "chore(release): version ${nextRelease.version}\n\n${nextRelease.notes}"
				}
			]
		]
	}
}
