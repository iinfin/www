		"util:lint:fix": "next lint --fix",
		"util:lint:staged": "lint-staged --concurrent false",
		"util:prettier": "npx prettier --write ./src --ignore-path .gitignore",
		"util:types": "tsc --noEmit --pretty",
		"tests------------------------------": "",
		"test:all": "echo \"No tests yet\""
